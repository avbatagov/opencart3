{% if blocks %}
<div class="reviews__random--block">
	<div class="reviews__padding--top">
		<div class="main-title">
		{% if heading_title %}
			<h2>{{ heading_title }}</h2>
		{% endif %}
		</div>
	</div>
	<div class="html-box">
		<div class="reviews__mainpage--slider">
		{% for block in blocks %}
			<div class="reviews__slider--item">
				<div class="image__title--reviews">
					<div class="image__block--reviews" style="background: url('{{ block.image }}') center center no-repeat; background-size: cover;">
					</div>
					<div class="title__date--reviews">
						<b>{{ block.title }}</b>
						<span>{{ block.date }}</span>
						<div class="rating__block--reviews">
							{% if block.rating %}
								{% for i in range(1, block.rating) %}
									<i class="fa fa-star"></i>
								{% endfor %}
							{% endif %}
						</div>
					</div>
				</div>
				<div class="caption__block--reviews">
					<p>{{ block.description }}</p>
				</div>
			</div>
		{% endfor %}
		</div>
	</div>
</div>
<script>
$('.reviews__mainpage--slider').slick({
	dots: true,
	infinite: false,
	speed: 300,
	slidesToShow: 3,
	slidesToScroll: 1,
	prevArrow: '<a class="slick-prev"><i class="fa fa-chevron-left"></i></a>',
	nextArrow: '<a class="slick-next"><i class="fa fa-chevron-right"></i></a>',
	responsive: [
		{
			breakpoint: 1199,
			settings: {
				slidesToShow: 2,
				slidesToScroll: 1,
				infinite: true,
				dots: true
			}
		},
		{
			breakpoint: 800,
			settings: {
				slidesToShow: 1,
				slidesToScroll: 1
			}
		},
	]
});
</script>
{% endif %}

